# BantuMarket Environment Configuration Template
# Copy this file to .env and fill in your actual values

# IBM watsonx Orchestrate Configuration
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_ORCHESTRATE_ENDPOINT=/v1/orchestrate/agents

# IBM Granite Model Configuration
GRANITE_MULTILINGUAL_MODEL=ibm/granite-20b-multilingual
GRANITE_INSTRUCT_MODEL=ibm/granite-3.0-8b-instruct
GRANITE_GUARDIAN_MODEL=ibm/granite-guardian-3.0-8b

# Bright Data MCP Gateway Configuration
BRIGHT_DATA_API_KEY=your_bright_data_api_key
BRIGHT_DATA_ZONE=your_zone_name
BRIGHT_DATA_HOST=brd.superproxy.io
BRIGHT_DATA_PORT=22225

# Application Configuration
APP_NAME=BantuMarket
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# Security Configuration
SECRET_KEY=your_secret_key_here_change_in_production
ENCRYPTION_KEY=your_encryption_key_here

# Database Configuration (if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/bantumarket

# Streamlit Dashboard Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_THEME=light

# API Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_CONCURRENT_REQUESTS=10

# Monitoring & Telemetry
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
ENABLE_LOGGING=true

# AfCFTA Data Sources
AFCFTA_API_ENDPOINT=https://api.afcfta.example.com
BORDER_PORTS_API=https://ports.afcfta.example.com
COMMODITY_PRICES_API=https://prices.afcfta.example.com